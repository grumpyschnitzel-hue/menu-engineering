# Anthropic API key — used for AI column mapping on CSV upload
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Kit (ConvertKit) — public API key for email capture forms
# Get from: Kit → Settings → Advanced → API Key
NEXT_PUBLIC_CONVERTKIT_API_KEY=your_kit_api_key_here

# Kit form ID — subscribers added to this form on email gate unlock
# Get from: Kit → Landing Pages & Forms → select form → URL contains the ID
NEXT_PUBLIC_CONVERTKIT_FORM_ID=your_kit_form_id_here
